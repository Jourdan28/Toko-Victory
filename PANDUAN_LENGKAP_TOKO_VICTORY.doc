<h3><span style='font-family:"Calibri",sans-serif;mso-fareast-font-family:"Times New Roman"'>5.4
Alur Kode ROP — Step by Step<o:p></o:p></span></h3>

<h4><span style='font-family:"Calibri",sans-serif;mso-fareast-font-family:"Times New Roman"'>Langkah
1: <span class=SpellE>Kumpulkan</span> data <span class=SpellE>permintaan</span>
(includes/<span class=SpellE>rop.php</span> → <span class=SpellE>hitung_<span
class=GramE>rop</span></span><span class=GramE>(</span>))<o:p></o:p></span></h4>

<div style='mso-element:para-border-div;border:none;border-left:solid #4299E1 3.0pt;
padding:0cm 0cm 0cm 9.0pt;background:#EDF2F7'><pre><span style='color:#1A202C'><o:p>&nbsp;</o:p></span></pre><pre><span
style='color:#1A202C'>// Ambil total <span class=SpellE>barang</span> KELUAR per <span
class=SpellE>hari</span>, 30 <span class=SpellE>hari</span> <span class=SpellE>terakhir</span><o:p></o:p></span></pre><pre><span
style='color:#1A202C'>SELECT COALESCE(<span class=GramE>SUM(</span><span
class=SpellE>jumlah</span>), 0) AS total<o:p></o:p></span></pre><pre><span
style='color:#1A202C'>FROM <span class=SpellE>transaksi</span><o:p></o:p></span></pre><pre><span
style='color:#1A202C'>WHERE <span class=SpellE>id_barang</span> <span
class=GramE>= ?</span> AND <span class=SpellE>jenis</span> = '<span
class=SpellE>keluar</span>'<o:p></o:p></span></pre><pre><span style='color:
#1A202C'>AND <span class=SpellE>created_at</span> &gt;= DATE_SUB(<span
class=GramE>NOW(</span>), INTERVAL 30 DAY)<o:p></o:p></span></pre><pre><span
style='color:#1A202C'>GROUP BY <span class=GramE>DATE(</span><span
class=SpellE>created_at</span>)<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><o:p>&nbsp;</o:p></span></pre><pre><span
style='color:#1A202C'>// <span class=SpellE>Hitung</span>:<o:p></o:p></span></pre><pre><span
class=SpellE><span style='color:#1A202C'>demand_avg</span></span><span
style='color:#1A202C'> = <span class=SpellE>total_semua_hari</span> / <span
class=SpellE>jumlah_hari_ada_transaksi</span><o:p></o:p></span></pre><pre><span
class=SpellE><span style='color:#1A202C'>demand_max</span></span><span
style='color:#1A202C'> = <span class=GramE>MAX(</span><span class=SpellE>total_per_hari</span>)<o:p></o:p></span></pre></div>

<h4><span style='font-family:"Calibri",sans-serif;mso-fareast-font-family:"Times New Roman"'>Langkah
2: <span class=SpellE>Terapkan</span> <span class=SpellE>rumus</span>
(includes/<span class=SpellE>inventory_helpers.php</span> → <span class=SpellE><span
class=GramE>autoCalculateRop</span></span><span class=GramE>(</span>))<o:p></o:p></span></h4>

<div style='mso-element:para-border-div;border:none;border-left:solid #4299E1 3.0pt;
padding:0cm 0cm 0cm 9.0pt;background:#EDF2F7'><pre><span style='color:#1A202C'><o:p>&nbsp;</o:p></span></pre><pre><span
style='color:#1A202C'>function <span class=SpellE><span class=GramE>autoCalculateRop</span></span><span
class=GramE>(</span>$<span class=SpellE>stok</span>, $<span class=SpellE>demand_avg</span>, $<span
class=SpellE>demand_max</span>, $<span class=SpellE>delivery_avg</span>, $<span
class=SpellE>delivery_<span class=GramE>max</span></span><span class=GramE>) {</span><o:p></o:p></span></pre><pre><span
style='color:#1A202C'><o:p>&nbsp;</o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>    </span>// JIKA <span
class=SpellE>ada</span> data <span class=SpellE>permintaan</span> &amp; lead time:<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>    </span>if ($<span
class=SpellE>demand_avg</span> &gt; 0 &amp;&amp; $<span class=SpellE>delivery_avg</span> &gt; <span
class=GramE>0) {</span><o:p></o:p></span></pre><pre><span style='color:#1A202C'><span style='mso-spacerun:yes'>        </span>$dm = $<span
class=SpellE>demand_max</span> &gt; <span class=GramE>0 ?</span> $<span
class=SpellE>demand_<span class=GramE>max</span></span><span class=GramE> :</span> <span
class=GramE>ceil(</span>$<span class=SpellE>demand_avg</span> * 1.5);<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>        </span>$<span
class=SpellE>lm</span> = $<span class=SpellE>delivery_max</span> &gt; <span
class=GramE>0 ?</span> $<span class=SpellE>delivery_<span class=GramE>max</span></span><span
class=GramE> :</span> <span class=GramE>ceil(</span>$<span class=SpellE>delivery_avg</span> * 1.5);<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>        </span>$safety = <span
class=GramE>max(</span>0, <span class=GramE>round(</span>($dm * $<span
class=SpellE>lm</span>) - ($<span class=SpellE>demand_avg</span> * $<span
class=SpellE>delivery_avg</span>)));<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>        </span>$<span
class=SpellE>rop</span><span style='mso-spacerun:yes'>    </span>= <span
class=GramE>max(</span>1, <span class=GramE>ceil(</span>($<span class=SpellE>demand_avg</span> * $<span
class=SpellE>delivery_avg</span>) + $safety));<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>        </span>return ['<span
class=SpellE>safety_stock</span>' =&gt; $safety, '<span class=SpellE>rop</span>' =&gt; $<span
class=SpellE>rop</span>];<o:p></o:p></span></pre><pre><span style='color:#1A202C'><span style='mso-spacerun:yes'>    </span>}<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><o:p>&nbsp;</o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>    </span>// FALLBACK <span
class=SpellE>jika</span> <span class=SpellE>belum</span> <span class=SpellE>ada</span> <span
class=SpellE>riwayat</span> <span class=SpellE>keluar</span>:<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>    </span>if ($<span
class=SpellE>stok</span> &gt; <span class=GramE>0) {</span><o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>        </span>$safety = <span
class=GramE>max(</span>3, <span class=GramE>ceil(</span>$<span class=SpellE>stok</span> * 0.2)<span
class=GramE>);<span style='mso-spacerun:yes'>   </span></span>// 20% <span
class=SpellE>stok</span><o:p></o:p></span></pre><pre><span style='color:#1A202C'><span style='mso-spacerun:yes'>        </span>$<span
class=SpellE>rop</span><span style='mso-spacerun:yes'>    </span>= <span
class=GramE>max(</span>10, <span class=GramE>ceil(</span>$<span class=SpellE>stok</span> * 0.4)<span
class=GramE>);<span style='mso-spacerun:yes'>  </span>/</span>/ 40% <span
class=SpellE>stok</span><o:p></o:p></span></pre><pre><span style='color:#1A202C'><span style='mso-spacerun:yes'>        </span>return ['<span
class=SpellE>safety_stock</span>' =&gt; $safety, '<span class=SpellE>rop</span>' =&gt; $<span
class=SpellE>rop</span>];<o:p></o:p></span></pre><pre><span style='color:#1A202C'><span style='mso-spacerun:yes'>    </span>}<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><o:p>&nbsp;</o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>    </span>// DEFAULT <span
class=SpellE>terakhir</span>:<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>    </span>return ['<span
class=SpellE>safety_stock</span>' =&gt; 5, '<span class=SpellE>rop</span>' =&gt; 10];<o:p></o:p></span></pre><pre><span
style='color:#1A202C'>}<o:p></o:p></span></pre></div>

<h4><span style='font-family:"Calibri",sans-serif;mso-fareast-font-family:"Times New Roman"'>Langkah
3: <span class=SpellE>Simpan</span> <span class=SpellE>ke</span> database
(includes/<span class=SpellE>rop.php</span>)<o:p></o:p></span></h4>

<div style='mso-element:para-border-div;border:none;border-left:solid #4299E1 3.0pt;
padding:0cm 0cm 0cm 9.0pt;background:#EDF2F7'><pre><span style='color:#1A202C'><o:p>&nbsp;</o:p></span></pre><pre><span
style='color:#1A202C'>UPDATE <span class=SpellE>barang</span> SET<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>  </span><span
class=SpellE>demand_avg</span> <span class=GramE>= ?</span>, <span
class=SpellE>demand_max</span> <span class=GramE>= ?</span>,<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>  </span><span
class=SpellE>delivery_avg</span> <span class=GramE>= ?</span>, <span
class=SpellE>delivery_max</span> <span class=GramE>= ?</span>,<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>  </span><span
class=SpellE>safety_stock</span> <span class=GramE>= ?</span>, <span
class=SpellE>rop</span> <span class=GramE>= ?</span><o:p></o:p></span></pre><pre><span
style='color:#1A202C'>WHERE id <span class=GramE>= ?</span><o:p></o:p></span></pre></div>

<h4><span style='font-family:"Calibri",sans-serif;mso-fareast-font-family:"Times New Roman"'>Langkah
4: <span class=SpellE>Tentukan</span> status <span class=SpellE>stok</span>
(includes/<span class=SpellE>inventory_helpers.php</span> → <span class=SpellE><span
class=GramE>getStokStatus</span></span><span class=GramE>(</span>))<o:p></o:p></span></h4>

<div style='mso-element:para-border-div;border:none;border-left:solid #4299E1 3.0pt;
padding:0cm 0cm 0cm 9.0pt;background:#EDF2F7'><pre><span style='color:#1A202C'><o:p>&nbsp;</o:p></span></pre><pre><span
style='color:#1A202C'>function <span class=SpellE><span class=GramE>getStokStatus</span></span><span
class=GramE>(</span>$<span class=SpellE>stok</span>, $<span class=SpellE><span
class=GramE>rop</span></span><span class=GramE>) {</span><o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>    </span>if ($<span
class=SpellE>stok</span> &lt;= 0)<span style='mso-spacerun:yes'>           </span>→ &quot;Habis&quot;<span
class=GramE><span style='mso-spacerun:yes'>   </span>(</span><span
class=SpellE>kritis</span>)<o:p></o:p></span></pre><pre><span style='color:
#1A202C'><span style='mso-spacerun:yes'>    </span>if ($<span class=SpellE>stok</span> &lt;= $<span
class=SpellE><span class=GramE>rop</span></span><span class=GramE>) {</span><o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>        </span>if ($<span
class=SpellE>stok</span>/$<span class=SpellE>rop</span> * 100 &lt; 30) → &quot;<span
class=SpellE>Kritis</span>&quot;<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>        </span>else<span style='mso-spacerun:yes'>                       </span>→ &quot;<span
class=SpellE>Menipis</span>&quot;<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>    </span>}<o:p></o:p></span></pre><pre><span
style='color:#1A202C'><span style='mso-spacerun:yes'>    </span>else<span style='mso-spacerun:yes'>                      </span>→ &quot;Aman&quot;<o:p></o:p></span></pre><pre><span
style='color:#1A202C'>}<o:p></o:p></span></pre></div>

